# Server
# For local Windows use, copy this file to local/.env. The legacy root .env is
# still supported and remains useful for Docker Compose variable expansion.
# Local installations already default to 127.0.0.1:8765 and local/data/.
# Docker Compose supplies its own 0.0.0.0 and /data overrides.
PAPERFIELD_AUTO_REFRESH=1

# Optional reserved ngrok domain for a stable beta-sharing address.
# Reserve it at https://dashboard.ngrok.com/domains before setting it here.
PAPERFIELD_NGROK_URL=

# Optional Paperfield-only AI override.
# Leave blank on a local Windows installation to use the active CC Switch provider.
PAPERFIELD_OPENAI_API_KEY=
PAPERFIELD_OPENAI_BASE_URL=https://api.openai.com/v1
PAPERFIELD_OPENAI_MODEL=gpt-5-mini
# Use responses or chat_completions when an explicit Paperfield API override is set.
PAPERFIELD_OPENAI_WIRE_API=responses

# Optional LibreTranslate-compatible service. When blank, Paperfield uses the
# browser's local Translator API first and a no-key Google endpoint as fallback.
PAPERFIELD_TRANSLATE_ENDPOINT=
PAPERFIELD_TRANSLATE_API_KEY=

# Optional GitHub token. Anonymous project discovery also works.
GITHUB_TOKEN=

# Optional unstable DBLP supplement.
PAPERFIELD_ENABLE_DBLP=0

# Optional S3-compatible cloud archive. Supports Cloudflare R2, Backblaze B2,
# AWS S3, and other providers exposing the S3 API.
PAPERFIELD_S3_PROVIDER=
PAPERFIELD_S3_ENDPOINT=
PAPERFIELD_S3_REGION=auto
PAPERFIELD_S3_BUCKET=
PAPERFIELD_S3_ACCESS_KEY_ID=
PAPERFIELD_S3_SECRET_ACCESS_KEY=

# Local PDF cache size. Cloud PDFs are downloaded on demand and old cached
# files are removed when this limit is exceeded.
PAPERFIELD_LOCAL_CACHE_MAX_MB=2048
# Cloudflare dashboard billing cycle start day (1-28).
PAPERFIELD_R2_BILLING_CYCLE_DAY=1

# Public GitHub source cache safety limits. Downloaded repository code is never executed.
PAPERFIELD_PROJECT_ZIP_MAX_MB=120
PAPERFIELD_PROJECT_TEXT_MAX_MB=200
# Archive downloads move to a background job. When a ZIP is too large or slow,
# Paperfield falls back to a bounded curated source snapshot.
PAPERFIELD_PROJECT_ARCHIVE_TIMEOUT_SECONDS=40
PAPERFIELD_PROJECT_ARCHIVE_REPOSITORY_MAX_MB=96
PAPERFIELD_PROJECT_SELECTIVE_MAX_FILES=180
PAPERFIELD_PROJECT_SELECTIVE_TEXT_MAX_MB=24
PAPERFIELD_PROJECT_SELECTIVE_WORKERS=6
PAPERFIELD_PROJECT_SELECTIVE_FILE_TIMEOUT_SECONDS=12
